# ─── Gemini AI ───
# Get your free API key from: https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here

# ─── Google Sheets ───
# Path to the service account JSON key file
# Setup: https://docs.gspread.org/en/latest/oauth2.html#for-bots-using-service-account
GOOGLE_SHEETS_CRED_PATH=./credentials/service_account.json

# The spreadsheet ID from the Google Sheets URL
# Example: https://docs.google.com/spreadsheets/d/SPREADSHEET_ID/edit
GOOGLE_SHEET_ID=your_google_sheet_id_here

# ─── Telegram Bot ───
# Create a bot via @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Your personal chat ID (get it from @userinfobot on Telegram)
TELEGRAM_CHAT_ID=your_chat_id_here

# ─── Ollama (Local LLM Fallback) ───
# Only needed if Gemini quota is exhausted
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1

# ─── Application Settings ───
LOG_LEVEL=INFO
MAX_DAILY_APPLICATIONS=10
MIN_ATS_SCORE=80
DRY_RUN=false
